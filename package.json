{
  "name": "@jafps/plugin-ip",
  "version": "1.1.0",
  "description": "Fastify plugin for determining the address of a proxied request.",
  "type": "module",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc",
    "test": "node --enable-source-maps --experimental-test-coverage --test-coverage-exclude \"src/**/__tests__/*.ts\" --test \"./dist/**/__tests__/*.{spec,test}.js\"",
    "lint": "eslint"
  },
  "author": "Joshua Avalon",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jafpsjs/plugin-ip.git"
  },
  "bugs": {
    "url": "https://github.com/jafpsjs/plugin-ip/issues"
  },
  "homepage": "https://github.com/jafpsjs/plugin-ip#readme",
  "imports": {
    "#func": {
      "import": "./dist/func/index.js"
    },
    "#hook": {
      "import": "./dist/hook/index.js"
    },
    "#symbol": {
      "import": "./dist/symbol.js"
    },
    "#type": {
      "import": "./dist/type.js"
    }
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "keywords": [
    "fastify",
    "fastify-plugin"
  ],
  "files": [
    "dist/**/*",
    "!dist/**/__tests__/**/*"
  ],
  "devDependencies": {
    "@joshuaavalon/eslint-config-javascript": "^11.0.3",
    "@joshuaavalon/eslint-config-typescript": "^11.0.0",
    "@types/node": "^25.7.0",
    "eslint": "^10.3.0",
    "fastify": "^5.8.5",
    "globals": "^17.6.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  },
  "dependencies": {
    "@fastify/proxy-addr": "^5.1.0",
    "fastify-plugin": "^5.1.0"
  }
}
